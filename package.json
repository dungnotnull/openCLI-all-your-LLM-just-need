{
  "name": "opencli",
  "version": "0.1.0",
  "description": "Multi-provider coding agent CLI for open-source LLMs",
  "type": "module",
  "main": "./dist/main.js",
  "bin": {
    "opencli": "./dist/main.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest",
    "test:mock": "vitest --mock",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write src/ tests/",
    "format:check": "prettier --check src/ tests/"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "cli",
    "agent",
    "llm",
    "coding",
    "open-source"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/open-cli/opencli"
  },
  "devDependencies": {
    "@types/node": "^20.19.41",
    "@types/pino": "^7.0.4",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vitest/coverage-v8": "^1.6.1",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-prettier": "^5.5.6",
    "prettier": "^3.8.3",
    "typescript": "^5.9.3",
    "vitest": "^1.6.1"
  },
  "dependencies": {
    "cosmiconfig": "^9.0.1",
    "pino": "^9.14.0",
    "zod": "^3.25.76"
  }
}
