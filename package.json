{
  "name": "opencli",
  "version": "0.1.0",
  "description": "Multi-provider coding agent CLI for open-source LLMs",
  "type": "module",
  "main": "./dist/main.js",
  "bin": {
    "opencli": "./dist/main.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest",
    "test:mock": "vitest --mock",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write src/ tests/",
    "format:check": "prettier --check src/ tests/"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "cli",
    "agent",
    "llm",
    "coding",
    "open-source"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/open-cli/opencli"
  },
  "devDependencies": {
    "@types/node": "^20.19.41",
    "typescript": "^5.9.3"
  }
}
